# AgncyPay Environment Configuration
# Copy this to .env and fill in actual values

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agncypay?schema=public

# QuickBooks Integration
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_WEBHOOK_TOKEN=
QUICKBOOKS_BASE_URL=https://sandbox-quickbooks.api.intuit.com
QUICKBOOKS_ENV=sandbox

# Column Bank Integration
COLUMN_API_KEY=
COLUMN_BASE_URL=https://api.column.com
COLUMN_WEBHOOK_SECRET=

# Credit System
CREDIT_MAX_EXPOSURE_MULTIPLIER=0.8
CREDIT_DEFAULT_INTEREST_RATE=0.0
CREDIT_MIN_SCORE_APPROVAL=60
CREDIT_MIN_SCORE_PARTIAL=40

# Idempotency
IDEMPOTENCY_TTL_SECONDS=86400
